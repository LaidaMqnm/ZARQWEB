# ============================================================
#  NEEDMONEY4MUSIC — variables de entorno
#  Copia este archivo a .env.local y rellena con tus claves.
#  En Vercel: Project Settings -> Environment Variables.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key
# Solo en el servidor (NO lleva prefijo NEXT_PUBLIC). Para inserts del embudo.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- Sitio ---
# Útil para los redirects de OAuth. En local: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Spotify ---
# ID de tu artista (lo ves en la URL del perfil: open.spotify.com/artist/<ID>)
NEXT_PUBLIC_SPOTIFY_ARTIST_ID=
# Playlist o álbum que sonará en el reproductor retro (formato URI o solo el id).
# Ej: spotify:playlist:37i9dQZF1DXcBWIGoYBM5M
NEXT_PUBLIC_SPOTIFY_PLAYER_URI=
# Para el conteo de seguidores vía API (server-side). Client Credentials flow.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Próximo lanzamiento ---
# Fecha ISO del próximo drop para el countdown. Ej: 2026-08-01T00:00:00-06:00
NEXT_PUBLIC_NEXT_RELEASE_AT=
# Link de pre-save (Feature.fm / ToneDen / Hypeddit, etc.)
NEXT_PUBLIC_PRESAVE_URL=
